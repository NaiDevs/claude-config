# ============================================================
# MCP Secrets — copia este archivo a mcp.env y llena los valores
# mcp.env está en .gitignore y NUNCA se sube al repo
# ============================================================
#
# Convención de sufijos (para auto-detección en setup.ps1):
#   NOMBRE_DEV  → PostgreSQL  (genera MCP: pg-nombre)
#   NOMBRE_SS   → SQL Server  (genera MCP: ss-nombre)
#
# Convención VPN:
#   Agrega "# vpn" en la línea ANTES de la variable para marcarla como
#   VPN-required. El setup la agrega automáticamente a disabledMcpjsonServers
#   en Claude Code. Habilitala manualmente cuando tengas VPN activa.
#
#   Ejemplo:
#     # vpn
#     YALO_AUTH_DEV=postgresql://...
#
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────
# Formato: postgresql://usuario:password@host:puerto/nombre_db

# vpn
YALO_BO_LABODEGA_DEV=postgresql://postgres:password@host:5432/dbname

# vpn
LABODEGA_DEV=postgresql://postgres:password@host:5432/dbname

# vpn
CPA_DEV=postgresql://postgres:password@host:5432/dbname

# vpn
YALO_COBRO_DEV=postgresql://postgres:password@host:5432/dbname

# vpn
YALO_AUTH_DEV=postgresql://postgres:password@host:5432/dbname

# ── SQL Server ────────────────────────────────────────────────────────────
# Formato: Server=host,puerto;Database=nombre;User Id=usuario;Password=pass;TrustServerCertificate=True

# vpn
# CORINSA_SS=Server=host,1433;Database=corinsa;User Id=sa;Password=password;TrustServerCertificate=True

# ── Otros tokens ──────────────────────────────────────────────────────────

# GitHub → github.com/settings/tokens → Classic → permisos: repo, read:org, read:user
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# Resend → resend.com/api-keys
RESEND_API_KEY=re_your_key_here
