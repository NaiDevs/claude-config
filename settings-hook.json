{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "shell": "powershell",
            "command": "& 'C:\\Users\\naide\\.claude\\hooks\\on-git-commit.ps1'",
            "timeout": 15,
            "statusMessage": "Guardando en Obsidian..."
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "if": "PowerShell(git *)",
            "shell": "powershell",
            "command": "& 'C:\\Users\\naide\\.claude\\hooks\\on-git-commit.ps1'",
            "timeout": 15,
            "statusMessage": "Guardando en Obsidian..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "& 'C:\\Users\\naide\\OneDrive\\Documentos\\Proyectos\\Nai\\agent-ai-config\\auto-update.ps1' -Tool claude -Silent",
            "shell": "powershell",
            "async": true
          }
        ]
      }
    ]
  }
}
